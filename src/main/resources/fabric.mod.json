{
	"schemaVersion": 1,
	"id": "${mod_id}",
	"version": "${version}",
	"name": "${mod_name}",
	"description": "${mod_description}",
	"authors": [
		"${mod_author}"
	],
	"contact": {
		"homepage": "${mod_homepage}",
		"sources": "${mod_sources}",
		"issues": "${mod_issues}"
	},
	"license": "${mod_license}",
	"icon": "assets/labymod_menu/icon.png",
	"environment": "client",
	"entrypoints": {
		"main": [
			"labymod_menu.LabyModMenuMod"
		],
		"client": [
			"labymod_menu.client.LabyModMenuClient"
		],
		"modmenu": [
			"labymod_menu.client.config.ModMenuIntegration"
		]
	},
	"mixins": [
		"labymod_menu.mixins.json",
		{
			"config": "labymod_menu.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.19.2",
		"minecraft": "${supported_minecraft_version}",
		"java": ">=${java_version}",
		"fabric-api": "*"
	},
	"suggests": {
		"modmenu": "*"
	},
	"breaks": {
		"animated_mojang": "*"
	}
}
